generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   // "supplier" or "buyer"
  company   String?
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Supplier relations
  farm     Farm?
  // Buyer relations
  orders   Order[]   @relation("BuyerOrders")
  reviews  Review[]
  favorites Favorite[]
}

model Farm {
  id             String   @id @default(cuid())
  name           String
  location       String
  country        String
  description    String?
  practices      String?  // e.g. "Organic, Sustainable, Regenerative"
  certifications String?  // e.g. "USDA Organic, Fair Trade"
  verified       Boolean  @default(false)
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ownerId  String   @unique
  owner    User     @relation(fields: [ownerId], references: [id])
  products Product[]
  reviews  Review[]
  favorites Favorite[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String   // Vegetables, Fruits, Grains, Dairy, Meat, Seafood
  price       Float
  unit        String   // kg, liter, ton, bunch
  minOrder    String   // e.g. "500 kg"
  quantity    Float    // available stock
  organic     Boolean  @default(false)
  harvestDate DateTime?
  image       String?
  status      String   @default("active") // active, low_stock, out_of_stock
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmId     String
  farm       Farm       @relation(fields: [farmId], references: [id])
  orderItems OrderItem[]
}

model Order {
  id        String   @id @default(cuid())
  status    String   @default("processing") // processing, shipped, delivered, cancelled
  total     Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyerId  String
  buyer    User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  items    OrderItem[]
  shipment Shipment?
}

model OrderItem {
  id       String @id @default(cuid())
  quantity Float
  price    Float
  unit     String

  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Shipment {
  id       String @id @default(cuid())
  carrier  String
  origin   String
  destination String
  status   String @default("preparing") // preparing, in_transit, delivered
  progress Int    @default(0)
  eta      DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User @relation(fields: [userId], references: [id])
  farmId String
  farm   Farm @relation(fields: [farmId], references: [id])

  @@unique([userId, farmId])
}

model Payout {
  id        String   @id @default(cuid())
  amount    Float
  method    String   @default("bank_transfer")
  status    String   @default("completed") // pending, completed, failed
  farmId    String
  createdAt DateTime @default(now())
}
